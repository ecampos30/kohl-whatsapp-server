# Inbound bridge — required for chatbot logic to run
WEBHOOK_INBOUND_URL=https://<project-ref>.supabase.co/functions/v1/whatsapp-webhook/incoming

# Supabase project (reference only — used by the Edge Function, not the server directly)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Public URL of this Baileys server (used by the Edge Function to send outbound replies)
BAILEYS_SERVER_URL=http://<your-server-ip>:3000
